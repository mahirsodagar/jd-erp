# ====================================================================
# JD Institute ERP — .env reference
# ====================================================================
#
# Copy what you need into your real .env (one for local dev, one on PA).
# Lines beginning with `#` are comments. Empty values are treated as
# "unset" — settings.py falls back to its hardcoded default.
#
# Where this file applies:
#   - LOCAL dev (your Mac):  /Volumes/New Volume/Project SSD/jd-erp/.env
#   - PRODUCTION  (PA):      /home/mahirsodagar/jd-erp/.env
#
# Different values per environment are common. Sections marked
# [REQUIRED] must be set or Django won't start.
#
# ====================================================================


# --- Django core [REQUIRED] -----------------------------------------

# Generate a fresh 50-char random string for prod; never reuse the dev one.
SECRET_KEY=dev-only-secret-do-not-use-in-prod-2pq85ym-xvp-oze-2r0

# True locally, False in prod.
DEBUG=True

# Comma-separated. On PA: "mahirsodagar.pythonanywhere.com"
ALLOWED_HOSTS=localhost,127.0.0.1


# --- Database ------------------------------------------------------

# SQLite is fine for current scale.
# On PA the file lives at /home/mahirsodagar/jd-erp/db.sqlite3
DATABASE_URL=sqlite:///db.sqlite3


# --- CORS / CSRF ----------------------------------------------------

# Allow the React frontend to call this API. Comma-separated, no spaces.
# Local:  http://localhost:3000,http://localhost:5173
# Prod:   https://jdsd.netlify.app,https://mahirsodagar.pythonanywhere.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Same hosts plus the API host itself.
# Local:  http://localhost:8000
# Prod:   https://mahirsodagar.pythonanywhere.com,https://jdsd.netlify.app
CSRF_TRUSTED_ORIGINS=http://localhost:8000


# --- JWT tokens ----------------------------------------------------

# 15 min access + 45 min refresh = sensible defaults.
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_MINUTES=45


# --- Rate limiting (DRF throttles) ---------------------------------

# Override only if you hit limits in real use.
# THROTTLE_USER=100/min
# THROTTLE_ANON=60/min
# THROTTLE_LOGIN=10/min
# THROTTLE_PASSWORD_CHANGE=5/min
# THROTTLE_FORGOT_PASSWORD=5/hour
# THROTTLE_LEAD_INTAKE=120/hour


# --- Login lockout (django-axes) ------------------------------------

AXES_FAILURE_LIMIT=5
AXES_COOLOFF_MINUTES=15


# --- Public Lead intake API ----------------------------------------

# Static API key for external lead-source webhooks.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
LEAD_INTAKE_API_KEY=dev-only-intake-key-change-me-in-prod


# --- Frontend URLs (used in emails / SMS) --------------------------

# Where the staff CRM lives. No trailing slash.
FRONTEND_BASE_URL=https://jdsd.netlify.app

# Where students log in. Separate host from staff. Trailing slash OK.
STUDENT_PORTAL_LOGIN_URL=https://jdsd.netlify.app/#/portal/login/

# Per-institute short URLs for the fee payment landing page.
# FEE_LINK_URL_JDIFT=https://9cfb.short.gy/jdinst
# FEE_LINK_URL_JDSD=https://9cfb.short.gy/jdsd


# --- Institute payment details (UPI + bank) ------------------------

# JSON blob. Override only when you have real account numbers.
# INSTITUTE_PAYMENT_DETAILS={"JDIFT": {"vpa": "jdift@hdfc", "payee_name": "JD Institute of Fashion Technology", "ac_name": "...", "ac_no": "...", "ifsc": "...", "bank": "HDFC Bank", "branch": "Bengaluru", "default_amount": "1000"}, "JDSD": {...}}


# --- Leaves ---------------------------------------------------------

# Skip Sat/Sun + national holidays when counting leave days.
LEAVES_EXCLUDE_HOLIDAYS_AND_WEEKENDS=True

# Where employee leave applications notify HR.
LEAVES_HR_INBOX=leave@jdinstitute.edu.in


# ====================================================================
# SMS configuration
# ====================================================================

# Active provider: "bulksms" (default) or "msg91".
# BulkSMS requires the host to allow outbound to api.bulksmsgateway.in.
# That's blocked on PA's free tier — upgrade PA or use MSG91 there.
SMS_PROVIDER=bulksms


# --- BulkSMS [primary, when SMS_PROVIDER=bulksms] -------------------

# Defaults match the legacy PHP project's hardcoded credentials.
BULK_SMS_USER=jdinstitute
BULK_SMS_PASSWORD=JDInstitute321!
BULK_SMS_SENDER=JDEDUC

# DLT Content Template IDs — already DLT-approved under PE JDEDUC.
# Defaults in settings.py work; override only if you re-register.
# DLT_TPL_APPLICATION_LINK=1307167852052800815
# DLT_TPL_FEE_LINK=1307168958796572350
# DLT_TPL_STUDENT_ABSENT=1307167524495832485
# DLT_TPL_PARENT_ABSENT=1307167525522133170
# DLT_TPL_STUDENT_ABSENT_V2=1307168612006682942
# DLT_TPL_PARENT_ABSENT_V2=1307168611999645882
# DLT_TPL_INSTALLMENT_DUE_STUDENT=1307167525346509509
# DLT_TPL_INSTALLMENT_DUE_PARENT=1307167525541582049
# DLT_TPL_INSTALLMENT_PAID_STUDENT=1307167525451487583
# DLT_TPL_INSTALLMENT_PAID_PARENT=1307167525469517516
# DLT_TPL_FEE_BULK_REMINDER=1707177090290548299


# --- MSG91 SMS [fallback, only when SMS_PROVIDER=msg91] ------------

# Authkey from MSG91 dashboard → Authkeys → "SMS" row. Leave empty to
# share MSG91_AUTHKEY (the email one). Independent keys are safer.
MSG91_SMS_AUTHKEY=

# Sender ID registered on MSG91. Must match a DLT-approved header.
MSG91_SMS_SENDER_ID=JDEDUC

# 24-char flow IDs from MSG91 dashboard. Drop in here once each is
# verified by DLT. Empty → that template logs a "not configured"
# error in the dispatch log; other templates unaffected.
MSG91_FLOW_APPLICATION_LINK=6a1e9eff477d83056b094d53
MSG91_FLOW_FEE_LINK=6a1e9f1ec8032c5f4e09a642
MSG91_FLOW_STUDENT_ABSENT=
MSG91_FLOW_PARENT_ABSENT=
MSG91_FLOW_STUDENT_ABSENT_V2=
MSG91_FLOW_PARENT_ABSENT_V2=
MSG91_FLOW_INSTALLMENT_DUE_STUDENT=
MSG91_FLOW_INSTALLMENT_DUE_PARENT=
MSG91_FLOW_INSTALLMENT_PAID_STUDENT=
MSG91_FLOW_INSTALLMENT_PAID_PARENT=
MSG91_FLOW_FEE_BULK_REMINDER=


# ====================================================================
# Email configuration
# ====================================================================
#
# Two channels:
#   * External  → MSG91 (mail.jdinstitute.com)  — leads / students /
#     parents. Configured below under "MSG91 Email".
#   * Internal  → SMTP  (jdinstitute.edu.in)    — staff / faculty.
#     Configured below under "SMTP". This is also the fallback path
#     for any external template not yet registered on MSG91.
# ====================================================================


# --- MSG91 Email [external] ----------------------------------------

# Authkey from MSG91 dashboard → Authkeys → "Email" row.
MSG91_AUTHKEY=411327AvSZtxr9aUFW6669485dP1

# Verified sender on MSG91. Must match MSG91_DOMAIN.
MSG91_SENDER_EMAIL=admin@mail.jdinstitute.com

# Verified domain registered with MSG91.
MSG91_DOMAIN=mail.jdinstitute.com

# Network timeout in seconds.
MSG91_TIMEOUT=10


# --- Email — per-trigger sender domain ------------------------------
#
# The From domain varies by trigger; fee/admission mail also varies by
# the student's course type:
#   Diploma courses    → jdinstitute.edu.in
#   Degree / Bachelors → jdindia.com
#   password reset     → mail.jdinstitute.com
#   HR / leave         → jdinstitute.edu.in
# (Policy map lives in settings.EMAIL_SENDER_DOMAIN_POLICY.)
#
# Can this host open outbound SMTP? PythonAnywhere FREE blocks it — set
# False there and SMTP-routed mail downgrades to MSG91 (from
# mail.jdinstitute.com) where a template exists. Set True on hosts with
# full egress (local, paid PA, VPS) to send from the real course domains.
EMAIL_SMTP_OUTBOUND_ENABLED=True
#
# A domain only goes live once its verified From-address is set below.
# Until then, sends fall back to the MSG91 default (mail.jdinstitute.com)
# so nothing breaks. To activate jdinstitute.edu.in / jdindia.com:
#   1. Verify each domain on the MSG91 dashboard (Email → Domains).
#   2. Set its verified sender address here.
SENDER_MAIL_JDINSTITUTE=admin@mail.jdinstitute.com
SENDER_JDINSTITUTE_EDU=

# jdindia.com (Degree/Bachelors) sends via its OWN SMTP server, not
# MSG91. Set host + user to activate; this then takes precedence over
# MSG91 for any trigger that resolves to jdindia.com.
SMTP_JDINDIA_HOST=
SMTP_JDINDIA_PORT=587
SMTP_JDINDIA_USER=
SMTP_JDINDIA_PASSWORD=
SMTP_JDINDIA_USE_TLS=True
SMTP_JDINDIA_USE_SSL=False
# SMTP_JDINDIA_FROM=          # From shown to recipients; defaults to USER

# (MSG91 sender override for jdindia.com — unused now that it routes via
# dedicated SMTP above. Kept for completeness.)
SENDER_JDINDIA=

# Department / role inboxes — extra recipients/CC on certain triggers
# (fee receipt → Accounts; admission filled → Operations; relieving →
# Ops/Principal/VP/Academic Manager). Blank = recipient skipped.
ACCOUNTS_INBOX=
OPERATIONS_INBOX=
PRINCIPAL_INBOX=
VICE_PRINCIPAL_INBOX=
ACADEMIC_MANAGER_INBOX=


# --- SMTP [internal — REQUIRED on PA for staff mail] ---------------
#
# Without these set on PA, internal mails (staff password resets,
# employee leave decisions, HR notifications, task assignments)
# silently log to stderr and never deliver.

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False

EMAIL_HOST_USER=admin.a@jdinstitute.edu.in
EMAIL_HOST_PASSWORD=

# From-address shown to recipients on the SMTP channel.
DEFAULT_FROM_EMAIL=admin.a@jdinstitute.edu.in

# Display name wrapped around DEFAULT_FROM_EMAIL — recipients see
# "JD Communications <admin.a@jdinstitute.edu.in>" instead of just
# "admin.a@..."
DEFAULT_FROM_NAME=JD Communications


# --- WhatsApp — XIRCLS trigger API ---------------------------------
#
# XIRCLS bridges to the WhatsApp Business API. Each send references a
# pre-configured *trigger* (campaign) on the XIRCLS platform plus named
# *parameters* that fill the approved template. See
# apps/notifications/whatsapp.py and the XIRCLS_* block in settings.py.
#
# Master gate. WhatsApp-channel notifications stay queue-only (nothing is
# sent) until this is True. Turn it on ONLY after the keys + at least one
# trigger below are set — otherwise it would try to message every new
# lead the moment a signal fires.
WHATSAPP_ENABLED=False

# Api-key: XIRCLS Profile → Global Settings → Generate API Key.
XIRCLS_API_KEY=
# Whatsapp-Project-Key: WhatsApp by XIRCLS → Settings → Projects → Token.
XIRCLS_WHATSAPP_PROJECT_KEY=
# Default country code when a recipient number carries none (India = 91).
# XIRCLS_DEFAULT_COUNTRY_CODE=91
# XIRCLS_TIMEOUT=10
# Override the endpoint only if XIRCLS changes it.
# XIRCLS_API_URL=https://api.xircls.com/talk/api/v1/send_trigger_message/

# our template_key → XIRCLS campaign (trigger) name, exactly as created
# on the XIRCLS platform. Blank = "not mapped" (a clear error in the
# dispatch log, never a silent provider rejection).
XIRCLS_TRIGGER_LEAD_WELCOME=
XIRCLS_TRIGGER_HOT_FOLLOWUP=
XIRCLS_TRIGGER_CAMPUS_VISIT=
XIRCLS_TRIGGER_POST_VISIT=
XIRCLS_TRIGGER_NOT_ANSWERED=
XIRCLS_TRIGGER_ENROLLED=
XIRCLS_TRIGGER_STUDENT_ABSENT=
# Application-form link, sent with the SMS/email in send_application_link.
XIRCLS_TRIGGER_APPLICATION_FORM=application_form
